ANTHROPIC_API_KEY=sk-ant-buraya_anthropic_key
OPENAI_API_KEY=sk-buraya_openai_key

# Spotify Developer Dashboard > My Apps > Uygulama oluştur > Client ID / Secret
SPOTIFY_CLIENT_ID=buraya_spotify_client_id
SPOTIFY_CLIENT_SECRET=buraya_spotify_client_secret
# Redirect URI: Spotify uygulamasında tam bu değeri girmelisin:
SPOTIFY_REDIRECT_URI=http://127.0.0.1:5000/callback/spotify

# Flask session şifresi (rastgele bir şey yaz)
FLASK_SECRET=rastgele_bir_sifre_buraya
